# Notion API 配置
# 注册地址: https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token_here

# Notion 数据库 ID（从分享链接中提取）
NOTION_VENDORS_DATABASE_ID=your_vendors_database_id
NOTION_MODELS_DATABASE_ID=your_models_database_id
NOTION_NEWS_DATABASE_ID=your_news_database_id

# 站点信息
NEXT_PUBLIC_SITE_URL=https://yourusername.github.io/aipick
NEXT_PUBLIC_SITE_NAME=AIPick
NEXT_PUBLIC_SITE_DESCRIPTION=AI 聚合站 - 帮你选对 API
